# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# WhatsApp (Meta Cloud API)
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_meta_access_token
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token
# App Secret from Meta → App Settings → Basic. Verifies inbound webhooks are genuinely from Meta.
WHATSAPP_APP_SECRET=your_meta_app_secret
# Approved template for the proactive 7am daily push (Phase 2). Leave blank until Meta approves it.
WHATSAPP_DAILY_TEMPLATE=
WHATSAPP_TEMPLATE_LANG=en

# Flutterwave (UK account → NGN collection → GBP settlement)
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-xxxxxxxx
FLUTTERWAVE_SECRET_KEY=FLWSECK-xxxxxxxx
FLUTTERWAVE_ENCRYPTION_KEY=xxxxxxxx
FLUTTERWAVE_WEBHOOK_SECRET=your_webhook_hash

# Server (for Flutterwave webhook)
PORT=3456
WEBHOOK_URL=https://your-domain.com/webhook/flutterwave

# Scale-out (Phase 3): public base URL enables Telegram WEBHOOK mode (run multiple
# copies). Leave blank for local dev → polling. Railway sets RAILWAY_PUBLIC_DOMAIN
# automatically, so this is optional in production.
WEBHOOK_BASE_URL=
# Optional shared secret Telegram echoes back on each webhook call (verified on /webhook/telegram).
TELEGRAM_WEBHOOK_SECRET=
# Outbound pacing (messages/sec). Defaults: Telegram 25, WhatsApp 20.
TELEGRAM_RATE_PER_SEC=25
WHATSAPP_RATE_PER_SEC=20

# Database
# Postgres connection string. When set, the app uses Postgres; otherwise JSONL files (local dev).
# On Railway this is auto-referenced from the Postgres service.
DATABASE_URL=
DATA_DIR=./data

# Delivery times (WAT = UTC+1)
DEFAULT_DELIVERY_HOUR=7
DEFAULT_DELIVERY_MINUTE=0
