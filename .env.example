# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# WhatsApp (Meta Cloud API)
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_meta_access_token
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token

# Flutterwave (UK account → NGN collection → GBP settlement)
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-xxxxxxxx
FLUTTERWAVE_SECRET_KEY=FLWSECK-xxxxxxxx
FLUTTERWAVE_ENCRYPTION_KEY=xxxxxxxx
FLUTTERWAVE_WEBHOOK_SECRET=your_webhook_hash

# Server (for Flutterwave webhook)
PORT=3456
WEBHOOK_URL=https://your-domain.com/webhook/flutterwave

# Database
DATA_DIR=./data

# Delivery times (WAT = UTC+1)
DEFAULT_DELIVERY_HOUR=7
DEFAULT_DELIVERY_MINUTE=0
